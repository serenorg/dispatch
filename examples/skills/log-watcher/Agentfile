FROM dispatch/native:latest

NAME log-watcher
VERSION 0.1.0

SOUL SOUL.md
SKILL skills/log-watcher
HEARTBEAT FILE HEARTBEAT.md

MODEL claude-sonnet-4-6 PROVIDER anthropic
FALLBACK gpt-4o PROVIDER openai

TOOL BUILTIN memory_put RISK low
TOOL BUILTIN memory_get RISK low

MOUNT SESSION sqlite
MOUNT MEMORY sqlite
MOUNT ARTIFACTS local

SECRET LOG_PATH
SECRET ALERTS_PATH

LIMIT ITERATIONS 10
LIMIT TOOL_CALLS 20
LIMIT TOOL_OUTPUT 16384
TIMEOUT RUN 90s
TIMEOUT TOOL 15s
TIMEOUT LLM 60s

ENTRYPOINT heartbeat
